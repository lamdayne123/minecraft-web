<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Server SMP</title>
</head>
<body>
<h1>Server SMP Online</h1>
<div id="players">Loading player data...</div>
<script>
async function loadPlayers() {
    const res = await fetch('players.json');
    const players = await res.json();
    const container = document.getElementById('players');
    container.innerHTML = '';
    players.forEach(p => {
        const div = document.createElement('div');
        div.textContent = ${p.name} | Bounty: ${p.bounty || 0} | Reward: ${p.reward || 0};
        container.appendChild(div);
    });
}
loadPlayers();
setInterval(loadPlayers, 10000);
</script>
</body>
</html>
